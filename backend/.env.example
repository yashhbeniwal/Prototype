# Goat Farm ERP Backend Environment Variables
# Copy this to .env and fill in your values

# ─── App ───────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME="Goat Farm ERP"

# ─── Database ──────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/goatfarm_erp"

# ─── JWT Auth ──────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=change_me_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=90d

# ─── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── AWS S3 (Mumbai Region) ────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=goatfarm-erp-media
AWS_S3_PUBLIC_URL=https://goatfarm-erp-media.s3.ap-south-1.amazonaws.com

# ─── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ─── WhatsApp Business Cloud API ───────────────
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=goatfarm_whatsapp_verify_2026

# ─── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_VERIFY_TOKEN=goatfarm_telegram_verify_2026

# ─── Razorpay ──────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Email (SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM_NAME="Goat Farm ERP"
